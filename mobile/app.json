{
  "expo": {
    "name": "Velor",
    "slug": "velorvelor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "store.velorcommerce.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Velor uses Face ID to unlock the app and sign you in to your account.",
        "NSCameraUsageDescription": "Velor needs your camera to broadcast Live Shopping streams.",
        "NSMicrophoneUsageDescription": "Velor needs your microphone to broadcast Live Shopping streams."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#08080b",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "store.velorcommerce.app",
      "permissions": ["CAMERA", "RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "plugins": [
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "backgroundColor": "#08080b",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "owner": "bilsy144",
    "extra": {
      "eas": {
        "projectId": "3207e08b-8832-4dba-bc40-d690d70628d9"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/3207e08b-8832-4dba-bc40-d690d70628d9"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}