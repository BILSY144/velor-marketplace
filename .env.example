# Velor Marketplace -- environment variables actually read by this codebase.
# Regenerated 2026-07-13 from a full `grep -r process.env` sweep of app/ and
# lib/ -- the previous version of this file only listed 8 of the ~30+ vars
# the app actually reads, which is its own kind of risk: a var missing here
# is a var a new deploy target (or a developer setting up locally) has no
# way to discover except by hitting a runtime error in production.
#
# Never put real secret values in this file or commit one that has them --
# it exists purely to document what's needed. Copy to .env.local and fill in
# real values there for local development.
#
# Intentionally NOT listed: NODE_ENV, VERCEL_ENV, VERCEL_GIT_COMMIT_SHA,
# VERCEL_GIT_COMMIT_MESSAGE -- these are set automatically by the Vercel
# platform itself, never something a developer configures.

# Database (Neon Postgres)
DATABASE_URL=

# Auth (NextAuth v5)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Gates every /api/admin/* route (middleware.ts) and every /api/cron/* route
# (lib/cronAuth.ts) via an `Authorization: Bearer <secret>` header. Two
# separate secrets on purpose -- rotating one never affects the other.
ADMIN_SECRET=
CRON_SECRET=

# Stripe (payments, Connect payouts, subscriptions, Identity)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_STOREFRONT_PRICE_ID=

# Trolley (usetrolley.com) -- DEFAULT seller payout rail for countries
# Stripe Connect doesn't reach (added 2026-07-23 evening, replacing Dots
# after Dots.dev was confirmed a permanent dead end -- its Country field is
# hard-locked to United States businesses only, and Velor Commerce Ltd is
# UK-registered). Requires Trolley's Bank Transfer Activation (KYC review
# of Velor's own business -- submitted 2026-07-23, awaiting approval) before
# these keys exist. See docs/TROLLEY_SETUP.md and lib/trolley.ts.
TROLLEY_ACCESS_KEY=
TROLLEY_SECRET_KEY=
TROLLEY_API_BASE=

# Dots.dev -- LEGACY, PERMANENTLY UNUSABLE. Kept only so any seller row
# already stored as DOTS from before 2026-07-23 evening doesn't break; no
# seller is ever newly assigned this rail (see lib/payoutRail.ts). Do not
# re-attempt Dots signup -- its business Country field is hard-locked to
# United States only and cannot ever accept a UK-registered company.
DOTS_API_KEY=
DOTS_API_BASE=

# Payoneer -- LEGACY secondary seller payout rail. No longer auto-assigned
# to new sellers (see lib/payoutRail.ts) but kept wired in case its Mass
# Payouts partner application (pending since 2026-07-13; see CLAUDE.md) is
# ever approved.
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=
PAYONEER_PROGRAM_ID=
PAYONEER_API_BASE=

# Shipping (Shippo -- live rate quotes + free tracking registration only;
# Velor never buys labels, see app/api/dashboard/shipping/label/route.ts)
SHIPPO_API_KEY=
SHIPPO_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
# Every outreach send BCCs this address so a human sees a copy of what
# actually went out. Defaults to willsinclair144@gmail.com if unset.
MONITOR_EMAIL=

# AI (Anthropic API -- shopping assistant, seller-application screening,
# prospect qualification)
ANTHROPIC_API_KEY=

# Live streaming (LiveKit -- Velor Live)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Seller-scout search providers (app/api/cron/scout-sellers)
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BING_SEARCH_API_KEY=
ETSY_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=

# Outreach tuning -- all optional, sane defaults apply if unset
# ('true'/'false'; the outreach-auto cron skips sending only on 'false')
OUTREACH_ENABLED=true
OUTREACH_MAX_PER_RUN=30
QUALIFY_MAX_PER_RUN=40

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
