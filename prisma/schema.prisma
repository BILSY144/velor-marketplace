generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  DELISTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum ShipmentStatus {
  PENDING
  LABEL_PURCHASED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
}

enum SellerTier {
  STARTER
  PRO
  ENTERPRISE // retired 2026-07-15 — kept only so legacy rows never break; treated as PRO in code
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              String    @default("user")
  accounts          Account[]
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  reviews           Review[]
  sessions          Session[]
  seller            Seller?
  wishlistItems     WishlistItem[]
  setupToken            String?   @unique
  setupTokenExpiresAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Seller {
  id                            String    @id @default(cuid())
  userId                        String    @unique
  user                          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName                     String
  description                   String?   @db.Text
  country                       String?
  currency                      String    @default("GBP")
  stripeAccountId               String?   @unique
  stripeOnboarded               Boolean   @default(false)
  approved                      Boolean   @default(false)
  tier                          SellerTier @default(STARTER)
  stripeCustomerId              String?   @unique
  stripeSubscriptionId          String?   @unique
  subscriptionStatus            String?
  subscriptionCurrentPeriodEnd  DateTime?
  termsAcceptedAt               DateTime?
  termsVersion                  String?
  featuredSlotsUsed             Int       @default(0)
  featuredSlotsResetAt          DateTime?
  products                      Product[]
  orders                        Order[]
  shipments                     Shipment[]
  shippingProfile               SellerShippingProfile?
  discountCodes                 DiscountCode[]
  payouts                       Payout[]
  supportTickets                SupportTicket[]
  apiKeys                       ApiKey[]
  liveStreams                   LiveStream[]
  countryFounded                 CountryFounder?
  sellerScore                   Float     @default(0)
  sellerBadge                   String?
  sellerScoreUpdatedAt          DateTime?
  scoreBreakdown                Json?
  rankingScore                   Float     @default(0)
  storeTheme                    String    @default("classic")
  storefrontUnlocked            Boolean   @default(false)
  storeLogo                     String?
  payoutRail                    String    @default("STRIPE")
  payoneerPayeeId               String?   @unique
  identityVerified               Boolean   @default(false)
    // DEPRECATED (2026-07-18): foundingEligible/foundingPerksGrantedAt/
  // foundingBadge below were driven by SellerApplication.country, which
  // conflated the seller's registered business country with the culture
  // they sell -- see CountryFounder at the end of this file, which is the
  // live mechanism now. These fields are kept only so already-approved
  // rows don't break; nothing grants perks off them anymore.
// Founding-seller programme. foundingEligible is decided once, at approval
  // (lib/provisionSeller.ts): true only for the first approved seller from
  // a given country. It does NOT grant the perks by itself -- perks
  // (Pro tier at no charge, the founding badge) activate only once the
  // seller lists their first product; see lib/founding.ts. foundingBadge is
  // a separate flag from sellerBadge on purpose: sellerBadge is the
  // buyer-facing merit badge recalculated by the scoring cron and would
  // overwrite a value stored there.
  foundingEligible               Boolean   @default(false)
  foundingPerksGrantedAt         DateTime?
  foundingBadge                  Boolean   @default(false)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
}

model SellerShippingProfile {
  id        String   @id @default(cuid())
  sellerId  String   @unique
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name      String
  company   String?
  street1   String
  street2   String?
  city      String
  state     String?
  zip       String
  country   String
  phone     String?
  // Optional flat buffer (GBP) the seller adds on top of every live carrier
  // quote -- covers packaging materials and rate drift between quote time and
  // label purchase. Added server-side in app/api/shipping/rates; capped at 25.
  handlingFeeGBP Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String        @id @default(cuid())
  sellerId      String
  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title         String
  description   String?       @db.Text
  price         Float
  compareAt     Float?
  images        String[]
  category      String
  tags          String[]
  stock         Int           @default(0)
  status        ProductStatus @default(PENDING_REVIEW)
  featured      Boolean       @default(false)
  featuredAt    DateTime?
  weightGrams   Float?
  lengthCm      Float?
  widthCm       Float?
  heightCm      Float?
  hsCode        String?
  originCountry String?
  // Closed vocabulary terms (max 2) from lib/specialities.ts - the origin x
  // speciality lattice. Validated server-side via validateSpecialitySelection.
  specialities  String[]      @default([])
  isHandmade    Boolean       @default(false)
  makerStory    String?       @db.Text
  materials     String?
  requiresCertificate Boolean @default(false)
  certificates  ProductCertificate[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  messages      Message[]
  reviews       Review[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Order {
  id                String          @id @default(cuid())
  sellerId          String
  seller            Seller          @relation(fields: [sellerId], references: [id])
  // A single Stripe payment can now produce MULTIPLE Orders -- one per
  // seller in the cart (see lib/orders.ts). stripePaymentId is therefore no
  // longer unique on its own; the compound unique below is what keeps order
  // creation idempotent -- at most one Order per (payment, seller) pair,
  // exactly matching one parcel/shipment per seller per checkout.
  stripePaymentId   String?
  status            OrderStatus     @default(PENDING)
  deliveredAt       DateTime?
  subtotal          Float
  platformFee       Float           @default(0)
  sellerEarnings    Float           @default(0)
  currency          String          @default("gbp")
  customerEmail     String
  customerName      String?
  shippingAddress   Json?
  items             OrderItem[]
  returnRequests    ReturnRequest[]
  shipment          Shipment?
  payout            Payout?
  dispute           Dispute?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([stripePaymentId, sellerId])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  price      Float
  commission Float?
  variantId  String?
  color      String?
}


model Shipment {
  id                String          @id @default(cuid())
  sellerId          String
  seller            Seller          @relation(fields: [sellerId], references: [id])
  orderId           String          @unique
  order             Order           @relation(fields: [orderId], references: [id])
  shippoShipmentId  String?
  shippoRateId      String?
  shippoLabelId     String?
  trackingNumber    String?
  trackingUrl       String?
  carrier           String?
  status            ShipmentStatus  @default(PENDING)
  labelUrl          String?
  events            ShipmentEvent[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model DiscountCode {
  id          String    @id @default(cuid())
  sellerId    String
  seller      Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  code        String    @unique
  type        String    @default("PERCENTAGE")
  value       Float     @default(0)
  minOrder    Float?
  maxDiscount Float?
  usageLimit  Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  // Empty array = applies to the seller's entire catalogue (store-wide).
  // Non-empty = restricted to only these product IDs.
  productIds  String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Payout {
  id               String   @id @default(cuid())
  sellerId         String
  seller           Seller   @relation(fields: [sellerId], references: [id])
  orderId          String?  @unique
  order            Order?   @relation(fields: [orderId], references: [id])
  amount           Float
  currency         String   @default("gbp")
  stripeTransferId String?  @unique
  payoneerPayoutId String?  @unique
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AgentLog {
  id        String   @id @default(cuid())
  agentName String
  action    String
  details   Json?
  status    String   @default("success")
  createdAt DateTime @default(now())
}

model ReturnRequest {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerEmail String
  reason        String   @db.Text
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model SellerApplication {
  id                String    @id @default(cuid())
  businessName      String
  contactEmail      String
  contactName       String
  storeDescription  String?   @db.Text
  website           String?
  productCategories String[]
  sampleImages      String[]
  country           String?
  prospectId        String?
  // Ship-from address, captured at application time so every approved
  // seller already has a SellerShippingProfile the moment they're
  // provisioned (see lib/provisionSeller.ts) -- no seller can reach
  // checkout for their first product without one, closing the gap that
  // caused shipping/rates to fall back to a placeholder quote for sellers
  // who never got around to filling in Settings -> Shipping. Optional at
  // the schema level only so existing PENDING applications submitted
  // before this field existed don't break; the /apply form and API route
  // both require these for every NEW submission.
  shippingName      String?
  shippingCompany   String?
  shippingStreet1   String?
  shippingStreet2   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?
  shippingPhone     String?
  // Identity verification. No seller is approved without a VERIFIED document
  // check. Velor never receives or stores the document itself -- Stripe hosts
  // the capture and returns only a verdict. RESTRICTED means Stripe Identity is
  // legally barred from verifying this jurisdiction (China, Russia, Cuba, Iran,
  // North Korea, Syria); those wait for the Payoneer KYC rail.
  // NOT_STARTED | PENDING | PROCESSING | VERIFIED | FAILED | CANCELED | RESTRICTED
  verificationStatus    String    @default("NOT_STARTED")
  verificationSessionId String?   @unique
  verifiedAt            DateTime?
  verificationNotes     String?   @db.Text
  verificationRemindersSent      Int       @default(0)
  verificationReminderLastSentAt DateTime?
  status            String    @default("PENDING")
  reviewedAt        DateTime?
  reviewedBy        String?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SellerProspect {
  id           String        @id @default(cuid())
  name         String
  platform     String
  storeUrl     String
  email        String?
  category     String
  score        Int           @default(50)
  country      String?
  sellerType   String
  notes        String?
  status       String        @default("prospected")
  // AI qualification gate (lib/prospectQualify.ts, app/api/cron/
  // qualify-prospects). null = not yet screened. Stage 1 of outreach-auto
  // will only send to qualified === true -- a scout hit is a search-engine
  // guess, not a verified match, and William's standing rule is that
  // factory/wholesale/service businesses must never receive outreach.
  qualified          Boolean?
  qualificationNotes String?   @db.Text
  qualifiedAt        DateTime?
  outreachLogs OutreachLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model OutreachLog {
  id         String         @id @default(cuid())
  prospectId String
  prospect   SellerProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  emailType  String
  subject    String
  sentAt     DateTime       @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  country   String?
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  productId  String?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Dispute {
  id         String   @id @default(cuid())
  orderId    String   @unique
  raisedBy   String
  reason     String
  evidence   String?
  status     String   @default("OPEN")
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  status      String
  description String
  location    String?
  occurredAt  DateTime
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model FxRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  fetchedAt DateTime @default(now())

  @@unique([base, quote])
}


enum SupportPriority {
  STANDARD
  PRIORITY
}

enum SupportTicketStatus {
  OPEN
  RESOLVED
}

model SupportTicket {
  id        String               @id @default(cuid())
  sellerId  String?
  seller    Seller?              @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  name      String
  email     String
  subject   String
  message   String               @db.Text
  priority  SupportPriority      @default(STANDARD)
  status    SupportTicketStatus  @default(OPEN)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  sellerId   String
  seller     Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

enum LiveStreamStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveStream {
  id            String                     @id @default(cuid())
  sellerId      String
  seller        Seller                     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title         String
  description   String?                    @db.Text
  roomName      String                     @unique
  status        LiveStreamStatus           @default(SCHEDULED)
  scheduledFor  DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  productIds    String[]
  peakViewers   Int                        @default(0)
  reportCount   Int                        @default(0)
  recordingUrl  String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  viewerSessions LiveStreamViewerSession[]
  reports        LiveStreamReport[]

  @@index([sellerId])
  @@index([status])
}

model LiveStreamViewerSession {
  id         String     @id @default(cuid())
  streamId   String
  liveStream LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  identity   String
  joinedAt   DateTime   @default(now())
  leftAt     DateTime?

  @@index([streamId])
  @@index([joinedAt])
}

// One row per (stream, reporter) so a single account can never report the
// same stream more than once -- app/api/live/[room]/report/route.ts used to
// take an unauthenticated POST and blindly increment LiveStream.reportCount,
// so anyone (no session required) could script 3 requests and force ANY
// seller's live stream to auto-end. The route now requires a signed-in
// session and creates a row here per genuinely distinct reporter; the
// @@unique makes a repeat report from the same account a no-op instead of
// counting again.
model LiveStreamReport {
  id            String     @id @default(cuid())
  streamId      String
  liveStream    LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  reporterEmail String
  createdAt     DateTime   @default(now())

  @@unique([streamId, reporterEmail])
  @@index([streamId])
}

enum CertificateType {
  EXPORT_PERMIT
  IMPORT_PERMIT
  PHYTOSANITARY
  OTHER
}

enum CertificateStatus {
  PENDING
  VERIFIED
  REJECTED
}

// Certificate documents for regulated-material listings (CITES export/import
// permits, phytosanitary certificates, etc). A product with
// requiresCertificate set must have at least one VERIFIED certificate before
// it can be APPROVED. Documents are stored as compressed data URLs in
// Postgres (same zero-new-infrastructure pattern as Seller.storeLogo).
// Retained indefinitely as the audit trail regulators could request.
model ProductCertificate {
  id                 String            @id @default(cuid())
  productId          String
  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type               CertificateType   @default(EXPORT_PERMIT)
  documentData       String            @db.Text
  fileName           String?
  destinationCountry String?
  issuedBy           String?
  expiresAt          DateTime?
  status             CertificateStatus @default(PENDING)
  reviewNotes        String?           @db.Text
  reviewedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([productId])
  @@index([status])
}

// Password reset — email-verified, one-hour tokens (William's standing
// requirement, 2026-07-15). Token stored as a SHA-256 hash; the raw value
// only ever exists inside the emailed link.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Expo push tokens — one row per device, so launch events (opening bells,
// order updates) can notify the Velor app with the bell chime.
model PushToken {
  id         String   @id @default(cuid())
  token      String   @unique
  platform   String
  userId     String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

// On-demand page-translation cache -- one row per (source string, language).
// Written by app/api/translate; each unique string is translated by the
// Anthropic API exactly once per language, then served from here forever.
model TranslationCache {
  id         String   @id @default(cuid())
  hash       String
  lang       String
  source     String
  translated String
  createdAt  DateTime @default(now())

  @@unique([hash, lang])
}

// Per-IP daily counter of NEW (cache-miss, model-translated) strings --
// the anti-abuse budget on /api/translate (2026-07-17, William: protect
// translation spend). Cached strings are served freely and never counted.
model TranslationIpDaily {
  id    String @id @default(cuid())
  ip    String
  day   String // YYYY-MM-DD (UTC)
  count Int    @default(0)

  @@unique([ip, day])
}


// Founding credit is tied to the ORIGIN of the product a seller lists, not
// to where the seller's business is registered (Seller.country) -- a
// single seller may sell goods from several cultures, so credit is earned
// per listing's actual origin, not claimed at application time. Both
// countryCode and sellerId are unique: one founder per country, and each
// seller may found at most one country page (William, 2026-07-18). First
// APPROVED product from that origin wins the row; the unique constraints
// make a race between two sellers resolve safely with no extra locking.
// Written by lib/founding.ts's grantCountryFounderIfFirst(), called from
// the auto-moderate cron and the manual admin approval route -- the only
// two places a product actually transitions into APPROVED status.
model CountryFounder {
  id          String   @id @default(cuid())
  countryCode String   @unique
  countryName String
  sellerId    String   @unique
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId   String
  grantedAt   DateTime @default(now())
}
