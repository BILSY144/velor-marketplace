generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  DELISTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum ShipmentStatus {
  PENDING
  LABEL_PURCHASED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
}

enum SellerTier {
  STARTER
  PRO
  ENTERPRISE
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
  seller        Seller?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Seller {
  id                           String              @id @default(cuid())
  userId                       String              @unique
  user                         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName                    String
  description                  String?             @db.Text
  country                      String?
  stripeAccountId              String?             @unique
  stripeOnboarded              Boolean             @default(false)
  approved                     Boolean             @default(false)
  tier                         SellerTier          @default(STARTER)
  stripeCustomerId             String?             @unique
  stripeSubscriptionId         String?             @unique
  subscriptionStatus           String?
  subscriptionCurrentPeriodEnd DateTime?
  termsAcceptedAt              DateTime?
  termsVersion                 String?
  featuredSlotsUsed            Int                 @default(0)
  featuredSlotsResetAt         DateTime?
  products                     Product[]
  orders                       Order[]
  shipments                    Shipment[]
  shippingProfile              SellerShippingProfile?
  discountCodes                DiscountCode[]
  payouts                      Payout[]
  verification                 SellerVerification?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
}

model SellerVerification {
  id                 String             @id @default(cuid())
  sellerId           String             @unique
  seller             Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status             VerificationStatus @default(NOT_SUBMITTED)
  fullLegalName      String?
  dateOfBirth        String?
  nationality        String?
  idType             String?
  idDocumentUrl      String?            @db.Text
  businessName       String?
  businessType       String?
  businessRegNumber  String?
  businessCountry    String?
  taxId              String?
  businessDocUrl     String?            @db.Text
  verificationNotes  String?            @db.Text
  submittedAt        DateTime?
  reviewedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model SellerShippingProfile {
  id           String   @id @default(cuid())
  sellerId     String   @unique
  seller       Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name         String
  company      String?
  street1      String
  street2      String?
  city         String
  state        String?
  zip          String
  country      String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  sellerId    String
  seller      Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title       String
  description String?       @db.Text
  price       Float
  compareAt   Float?
  images      String[]
  category    String
  tags        String[]
  stock       Int           @default(0)
  status      ProductStatus @default(PENDING_REVIEW)
  featured    Boolean       @default(false)
  featuredAt  DateTime?
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  sellerId        String
  seller          Seller      @relation(fields: [sellerId], references: [id])
  stripePaymentId String?     @unique
  status          OrderStatus @default(PENDING)
  subtotal        Float
  platformFee     Float
  sellerEarnings  Float
  currency        String      @default("gbp")
  customerEmail   String
  customerName    String?
  shippingAddress Json?
  items           OrderItem[]
  shipment        Shipment?
  payout          Payout?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Shipment {
  id               String         @id @default(cuid())
  sellerId         String
  seller           Seller         @relation(fields: [sellerId], references: [id])
  orderId          String         @unique
  order            Order          @relation(fields: [orderId], references: [id])
  shippoShipmentId String?
  shippoRateId     String?
  shippoLabelId    String?
  trackingNumber   String?
  trackingUrl      String?
  carrier          String?
  status           ShipmentStatus @default(PENDING)
  labelUrl         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DiscountCode {
  id          String    @id @default(cuid())
  sellerId    String
  seller      Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  code        String    @unique
  discountPct Float
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Payout {
  id               String   @id @default(cuid())
  sellerId         String
  seller           Seller   @relation(fields: [sellerId], references: [id])
  orderId          String?  @unique
  order            Order?   @relation(fields: [orderId], references: [id])
  amount           Float
  currency         String   @default("gbp")
  stripeTransferId String?  @unique
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AgentLog {
  id        String   @id @default(cuid())
  agentName String
  action    String
  details   String?  @db.Text
  status    String   @default("success")
  createdAt DateTime @default(now())
}
